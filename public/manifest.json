{
  "manifest_version": 3,
  "name": "TabiNeko — Mouse Gestures",
  "short_name": "TabiNeko",
  "description": "High-performance right-click mouse gestures for tab and page navigation.",
  "version": "1.1.0",
  "permissions": ["tabs", "scripting", "storage", "activeTab", "sessions"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["gestureContent.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_title": "TabiNeko Gestures",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "assets/images/icon16.png",
    "32": "assets/images/icon32.png",
    "48": "assets/images/icon48.png",
    "128": "assets/images/icon128.png"
  },
  "minimum_chrome_version": "114"
}
