---
const gestureRows = [
  { seq: '→ ↓', action: 'Next Tab', icon: '🗂️' },
  { seq: '← ↑', action: 'Previous Tab', icon: '🧭' },
  { seq: '↑', action: 'Scroll to Top', icon: '⤒' },
  { seq: '↓', action: 'Scroll to Bottom', icon: '⤓' },
  { seq: '←', action: 'Go Back', icon: '↩️' },
  { seq: '→', action: 'Go Forward', icon: '↪️' },
  { seq: '↑ ↓', action: 'Reload (Shift = Hard)', icon: '🔄' },
  { seq: '↓ ↑', action: 'Duplicate Tab', icon: '🧬' },
  { seq: '→ ←', action: 'Close Tab', icon: '✖️' },
  { seq: '← →', action: 'Restore Last Closed Tab', icon: '♻️' },
  { seq: '↑ →', action: 'New Tab to Right', icon: '➕' },
  { seq: '↓ ←', action: 'Pin / Unpin Tab', icon: '📌' },
  { seq: '↑ ↓ ↑', action: 'Hard Reload', icon: '💨' },
];
---

<div class="popup-shell">
  <header class="header">
    <h1 class="wordmark">🐾 TabiNeko</h1>
    <p class="subtitle">Gesture Navigator</p>
  </header>

  <section class="sheet" aria-label="Gesture cheatsheet">
    {gestureRows.map((row, index) => (
      <div class="row" style={`--row-index:${index};`}>
        <span class="arrows" aria-label={row.seq}>
          {row.seq.split(' ').map((arrow, arrowIndex) => (
            <svg
              class="arrow"
              viewBox="0 0 28 28"
              role="img"
              aria-hidden="true"
              style={`--arrow-index:${arrowIndex};`}
            >
              <text x="14" y="19" text-anchor="middle">{arrow}</text>
            </svg>
          ))}
        </span>
        <span class="action">{row.action}</span>
        <span class="icon">{row.icon}</span>
      </div>
    ))}
  </section>

  <footer class="footer">
    <label class="toggle-row" for="enabled-toggle">
      <span>Enable Extension</span>
      <span class="toggle">
        <input id="enabled-toggle" type="checkbox" />
        <span class="slider"></span>
      </span>
    </label>
    <span class="version" id="version-badge">v1.0.0</span>
  </footer>
</div>

<style is:global>
  :root {
    --color-bg: #1a1f1e;
    --color-surface: #222927;
    --color-accent: #86ac7f;
    --color-accent-hover: #a8c9a0;
    --color-text: #e8ede7;
    --color-text-muted: #7a9178;
    --color-row-hover: rgba(134, 172, 127, 0.08);
    --shadow-soft: 0 2px 12px rgba(0, 0, 0, 0.4);
    --transition-fast: 150ms ease;
    --popup-open: 180ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
    background: var(--color-bg);
    color: var(--color-text);
  }

  .popup-shell {
    width: 320px;
    max-height: 520px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 14px;
    animation: popup-in var(--popup-open);
  }

  .header {
    background: var(--color-surface);
    border-radius: 14px;
    padding: 12px;
    box-shadow: var(--shadow-soft);
  }

  .wordmark { margin: 0; font-size: 24px; }
  .subtitle { margin: 4px 0 0; color: var(--color-text-muted); font-size: 13px; }

  .sheet {
    background: var(--color-surface);
    border-radius: 14px;
    box-shadow: var(--shadow-soft);
    overflow: auto;
    max-height: 380px;
    padding: 8px;
  }

  .row {
    display: grid;
    grid-template-columns: 86px 1fr auto;
    align-items: center;
    gap: 10px;
    border-radius: 10px;
    padding: 9px 10px;
    opacity: 0;
    transform: translateX(-8px);
    animation: row-in 220ms ease forwards;
    animation-delay: calc(var(--row-index) * 40ms);
    transition: background var(--transition-fast);
  }

  .row:hover { background: var(--color-row-hover); }

  .arrows { display: inline-flex; gap: 2px; }

  .arrow {
    width: 24px;
    height: 24px;
    fill: var(--color-accent);
    opacity: 0;
    transform: translateX(-6px);
    animation: arrow-in 220ms ease forwards;
    animation-delay: calc(var(--arrow-index) * 80ms + var(--row-index) * 20ms);
  }

  .arrow text { fill: var(--color-accent); font-size: 16px; font-weight: 700; }

  .action { font-size: 13px; }
  .icon { color: var(--color-text-muted); }

  .footer {
    background: var(--color-surface);
    border-radius: 14px;
    box-shadow: var(--shadow-soft);
    padding: 12px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .toggle-row { display: flex; align-items: center; gap: 10px; font-size: 13px; }

  .toggle input { display: none; }

  .slider {
    width: 40px;
    height: 22px;
    border-radius: 999px;
    display: inline-block;
    background: var(--color-bg);
    position: relative;
    transition: background var(--transition-fast);
  }

  .slider::after {
    content: '';
    position: absolute;
    top: 3px;
    left: 3px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--color-text);
    transition: transform var(--transition-fast);
  }

  .toggle input:checked + .slider {
    background: var(--color-accent);
  }

  .toggle input:checked + .slider::after {
    transform: translateX(18px);
  }

  .version {
    color: var(--color-text-muted);
    font-size: 11px;
    border: 1px solid var(--color-text-muted);
    border-radius: 999px;
    padding: 3px 8px;
  }

  @keyframes popup-in {
    from { opacity: 0; transform: scale(0.96); }
    to { opacity: 1; transform: scale(1); }
  }

  @keyframes row-in {
    to { opacity: 1; transform: translateX(0); }
  }

  @keyframes arrow-in {
    to { opacity: 1; transform: translateX(0); }
  }
</style>
